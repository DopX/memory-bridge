{
  "client": "copilot",
  "description": "GitHub Copilot hooks 配置模板",
  "status": "experimental",
  "config_path": "VS Code 插件机制",
  "notes": "格式类似 Claude Code（VS Code 插件机制）",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \"INSTALL_DIR/scripts/hooks/save.ps1\" \"CONFIG_PATH\"",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \"INSTALL_DIR/scripts/hooks/recall.ps1\" \"CONFIG_PATH\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
