{
  "client": "trae",
  "description": "Trae hooks 配置模板",
  "status": "experimental",
  "config_path": "待确认",
  "notes": "格式待定（文档不完整），先放占位模板",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \"INSTALL_DIR/scripts/hooks/save.ps1\" \"CONFIG_PATH\"",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \"INSTALL_DIR/scripts/hooks/recall.ps1\" \"CONFIG_PATH\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
