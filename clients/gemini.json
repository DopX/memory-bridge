{
  "client": "gemini",
  "description": "Gemini CLI hooks 配置模板",
  "status": "stable",
  "config_path": "~/.gemini/settings.json",
  "notes": "事件名不同于 Claude Code，timeout 单位是毫秒",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \"INSTALL_DIR/scripts/hooks/recall.ps1\" \"CONFIG_PATH\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \"INSTALL_DIR/scripts/hooks/save.ps1\" \"CONFIG_PATH\"",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
